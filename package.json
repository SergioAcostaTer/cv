{
    "name": "resume-generator",
    "version": "1.0.0",
    "description": "Generate HTML resumes from JSON data",
    "packageManager": "pnpm@10.8.0",
    "main": "src/cli.ts",
    "scripts": {
        "dev": "tsx src/cli.ts",
        "build": "tsx src/commands/generate.ts",
        "chat": "tsx src/commands/chat-cv.ts",
        "linkedin": "tsx src/commands/generate-linkedin.ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@clack/prompts": "^1.2.0",
        "handlebars": "^4.7.7",
        "marked": "^15.0.12",
        "marked-terminal": "^7.3.0",
        "openai": "^6.34.0",
        "picocolors": "^1.1.1",
        "puppeteer": "^24.37.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/marked-terminal": "^6.1.1",
        "@types/node": "^22.15.3",
        "@vitest/coverage-v8": "^4.1.4",
        "tsx": "^4.19.2",
        "typescript": "^5.8.3",
        "vitest": "^4.1.4"
    }
}