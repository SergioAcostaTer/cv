{
    "name": "resume-generator",
    "version": "1.0.0",
    "description": "Generate HTML resumes from JSON data",
    "packageManager": "pnpm@10.8.0",
    "main": "src/cli.ts",
    "scripts": {
        "dev": "tsx src/cli.ts",
        "build": "pnpm build:client && tsc --noEmit",
        "build:client": "vite build --config client/vite.config.ts --outDir ../dist-client",
        "build:resumes": "tsx src/commands/generate.ts",
        "dev:client": "vite --config client/vite.config.ts",
        "chat": "tsx src/commands/chat-cv.ts",
        "linkedin": "tsx src/commands/generate-linkedin.ts",
        "roadmap": "tsx src/commands/roadmap.ts",
        "dashboard": "tsx src/commands/dashboard.ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@clack/prompts": "^1.2.0",
        "cac": "^7.0.0",
        "class-variance-authority": "^0.7.1",
        "cli-highlight": "^2.1.11",
        "clipboardy": "^4.0.0",
        "clsx": "^2.1.1",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "handlebars": "^4.7.7",
        "lucide-react": "^1.8.0",
        "marked": "^15.0.12",
        "marked-terminal": "^7.3.0",
        "open": "^11.0.0",
        "openai": "^6.34.0",
        "picocolors": "^1.1.1",
        "puppeteer": "^24.37.2",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "tailwind-merge": "^3.5.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/marked-terminal": "^6.1.1",
        "@types/node": "^22.15.3",
        "@types/open": "^6.2.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.4",
        "autoprefixer": "^10.5.0",
        "postcss": "^8.5.10",
        "tailwindcss": "^4.2.2",
        "tsx": "^4.19.2",
        "typescript": "^5.8.3",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    }
}